DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"
NEXT_PUBLIC_MAPBOX_TOKEN="pk.your_mapbox_token_here"

# Cloudflare Realtime TURN — SERVER-SIDE ONLY. These are secrets and must NOT be
# prefixed NEXT_PUBLIC_ (that would ship them to the browser). They are read only
# by /api/turn-credentials to mint short-lived ICE credentials.
CLOUDFLARE_TURN_TOKEN_ID=
CLOUDFLARE_TURN_API_TOKEN=
