// Pulse — coordination store only. Nothing here is durable user data:
// rows are deleted on leave, on staleness, or after a signal is delivered.
// Chat text and video are NOT modeled — they ride WebRTC peer-to-peer and
// never reach the server.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Presence {
  id       String   @id // client-generated session uuid
  token    String // server-issued capability secret (CSPRNG); gates poll/leave/signal/turn. NEVER returned by poll.
  lat      Float // ALREADY privacy-offset coords (raw is never stored)
  lng      Float
  busy     Boolean  @default(false) // true while in an active connection
  lastSeen DateTime

  @@index([lastSeen])
}

model Signal {
  // Mailbox for connection requests + WebRTC signaling only.
  id        String   @id @default(uuid())
  toId      String // recipient session id
  fromId    String // sender session id
  type      String // request | accept | decline | offer | answer | ice | end
  payload   String? // JSON string (SDP / ICE candidate)
  createdAt DateTime @default(now())

  @@index([toId])
}

model RateLimit {
  // Fixed-window rate-limit counter. One row per (key, route, window bucket).
  // Transient like everything else: reaped lazily on poll once the window has
  // fully expired. Keyed by a hashed caller identifier so no raw id/token is
  // stored here.
  key       String // hashed caller identifier (e.g. sha256 of token or session id)
  route     String // logical bucket: "join" | "signal" | "poll"
  window    BigInt // window start as epoch-ms bucket (floor(now / windowMs) * windowMs)
  count     Int      @default(0) // requests seen in this window
  expiresAt DateTime // window end; rows past this are reapable

  @@id([key, route, window]) // upsert target — one row per caller/route/window
  @@index([expiresAt]) // serves the lazy reap delete
}
